{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(./scripts/verify.sh)",
      "Read(*)",
      "Edit(*)",
      "Write(specs/**)",
      "Write(docs/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf .)",
      "Bash(git push --force*)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(*--unsafe*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/require-spec.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-scope.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/summarize-session.sh"
          }
        ]
      }
    ]
  }
}